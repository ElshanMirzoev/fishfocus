@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using FishFocus.Shared.Models
@using System.Threading
@using MudBlazor
@using FishFocus.Client.Dialogs
@implements IDisposable

@using FishFocus.Shared.DTOs.Profile
@using System.Net.Http.Json
@using System.Net.Http.Headers

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider Configuration="@((SnackbarConfiguration config) => {
    config.SnackbarVariant = Variant.Filled;
    config.PositionClass = Defaults.Classes.Position.BottomLeft;
    config.PreventDuplicates = true;
    config.NewestOnTop = true;
    config.ShowCloseIcon = true;
})" />
<PageTitle>Рыбалка</PageTitle>


<div class="main-container @(isNightMode ? "night-theme" : "day-theme")"
     style="opacity: @(_isAppReady ? "1" : "0"); transition: opacity 0.8s ease-in-out;">

    <div class="lake-area" id="lake-container">
        @if (isRainInDom)
        {
            <div class="rain-overlay @(isRainAnimationActive ? "rain-active" : "")" @key="@("rain-layer-v6")">
                @if (_rainDrops != null)
                {
                    @foreach (var drop in _rainDrops)
                    {
                        <div class="rain-drop"
                             style="left: @(drop.Left.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;
                            animation-delay: @(drop.Delay.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s;
                            animation-duration: @(drop.Duration.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s;">
                        </div>
                    }
                }
            </div>
        }

        <div class="sky-part">
            <div class="clouds-visual-area">
                @foreach (var cloud in _activeClouds)
                {
                    <div class="cloud @cloud.Class @cloud.DirectionClass"
                         style="top: @(cloud.Top)%;
                        animation-duration: @(cloud.Duration)s;
                        animation-delay: @(cloud.NegDelay.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))s;">
                    </div>
                }
            </div>

            <div class="lightning-flash @(isLightningStrike ? "flash-active" : "")"></div>

            @if (_isAppReady)
            {
                <div class="birds-visual-area">
                    @foreach (var bird in _activeBirds)
                    {
                        <div class="bird-container @(bird.IsFlyingRight ? "fly-right" : "fly-left")"
                             style="top: @(bird.Top)%; animation-duration: @(bird.Speed.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))s; animation-delay: @(bird.Delay.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))s;"
                             @key="bird.Id">
                            <div class="bird @bird.BirdClass"></div>
                        </div>
                    }
                </div>
            }

            <div class="lightning-container">
                @foreach (var bolt in _activeBolts)
                {
                    <svg class="lightning-bolt"
                         style="left: @(bolt.Left)%; top: @(bolt.Top)%; width: @(bolt.Width)px; height: @(bolt.Height)px;"
                         viewBox="0 0 20 40" @key="bolt.Id">
                        <path d="M10 0 L2 20 L18 15 L8 40" fill="none" stroke="white" stroke-width="2" />
                    </svg>
                }
            </div>
        </div>

        <div class="water-part" @onclick="HandleLakeClick" @onmousemove="HandleMouseMove" @onclick:stopPropagation>
            <div class="fog-overlay @(playFog ? "fog-active" : "")"></div>

            <div class="fishing-ui-group">
                <div class="fishing-visual-layer">
                    <div class="progress-container">
                        <MudProgressCircular Value="@_progressValue"
                                             Size="Size.Large"
                                             Thickness="2"
                                             Class="main-progress-circle"
                                             Style="height:150px; width:150px;">
                        </MudProgressCircular>
                    </div>

                    <div class="fishing-scene @(GetContainerAnimationClass())">
                        <svg class="bobber-svg @(GetFishingAnimationClass()) @(GetFinalShakeClass())" viewBox="0 0 50 100" style="width: 50px; height: 100px;">
                            <line x1="25" y1="15" x2="25" y2="45" stroke="#ff3b30" stroke-width="3" stroke-linecap="round" />
                            <line x1="25" y1="28" x2="25" y2="40" stroke="#ffffff" stroke-width="3" />
                            <circle cx="25" cy="15" r="4.5" fill="#ffcc00" stroke="#1a252f" stroke-width="2" />
                            <path d="M 25 45 C 38 45, 40 65, 25 90 C 10 65, 12 45, 25 45 Z" fill="#2ecc71" stroke="#1a252f" stroke-width="2.5" />
                            <path d="M 15.5 54 C 18 48, 21 45, 25 45 C 29 45, 32 48, 34.5 54 Z" fill="#ff3b30" stroke="#1a252f" stroke-width="2" />
                            <line x1="25" y1="90" x2="25" y2="98" stroke="#1a252f" stroke-width="2.5" stroke-linecap="round" />
                        </svg>

                        <div class="ripples"></div>
                        <div class="splash-effect @(showSplash ? "splash-active" : "")"></div>
                    </div>
                </div>

                <MudText Typo="Typo.h1" Class="timer-text">@timeDisplay</MudText>

                <div class="quote-area">
                    <MudText Typo="Typo.body1" Class="italic-quote">"@_currentQuote"</MudText>
                </div>

                @if (_isAppReady)
                {
                    if (!isRunning && !_isLeaving)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="StartTimer" Class="action-button">
                            Забросить удочку
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="StopTimer" Class="action-button">
                            Прервать рыбалку
                        </MudButton>
                    }
                }
            </div>
        </div>
    </div>
    <div class="settings-panel">
        @if (_isLoggedIn)
        {
            <div class="profile-nav-card mb-4">
                <button type="button" class="avatar-nav-btn" @onclick="OpenProfileOrLogin" title="Личный кабинет">
                    <div class="nav-avatar-circle" style="background: @GetNavAvatarStyle();">
                        @if (AvatarData != null && AvatarData.StartsWith("data:image/"))
                        {
                            <img src="@AvatarData" class="nav-avatar-img" />
                        }
                        else
                        {
                            <span>@GetAvatarInitial()</span>
                        }
                    </div>
                </button>
                <div class="profile-nav-info" @onclick="OpenProfileOrLogin" style="cursor: pointer; flex-grow: 1; margin-left: 8px;">
                    <div class="profile-nav-name">@Username</div>
                    <div class="profile-nav-score">Очки: @TotalScore</div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Error" OnClick="Logout" Title="Выйти" />
            </div>
        }
        else
        {
            <div class="d-flex justify-center mb-4">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Inherit" 
                           StartIcon="@Icons.Material.Filled.AccountCircle" 
                           OnClick="OpenProfileOrLogin" 
                           FullWidth="true" 
                           Style="border-color: rgba(255,255,255,0.2);">
                    Войти в аккаунт
                </MudButton>
            </div>
        }
            
        <div class="time-picker-container mb-2">
            <div class="time-box">
                <div class="time-zone top" @onmousedown='(e) => HandleZoneClick("hours", 1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
                </div>
                <div class="time-zone middle" @onclick='() => EnableInputMode("hours")'>
                    @if (isHoursInputMode)
                    {
                        <input id="h-input-field" type="number" class="time-input-hidden" value="@displayHours" @onchange='(e) => ManualUpdate(e, "hours")' @onblur='() => isHoursInputMode = false' @onkeydown="@(e => { if (e.Key == "Enter") isHoursInputMode = false; })" />
                    }
                    <div class="time-content-wrapper"><span class="time-value">@displayHours</span><span class="time-label">ч</span></div>
                </div>
                <div class="time-zone bottom" @onmousedown='(e) => HandleZoneClick("hours", -1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                </div>
            </div>
            <div class="time-box">
                <div class="time-zone top" @onmousedown='(e) => HandleZoneClick("minutes", 1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
                </div>
                <div class="time-zone middle" @onclick='() => EnableInputMode("minutes")'>
                    @if (isMinutesInputMode)
                    {
                        <input id="m-input-field" type="number" class="time-input-hidden" value="@displayMinutes" @onchange='(e) => ManualUpdate(e, "minutes")' @onblur='() => isMinutesInputMode = false' @onkeydown="@(e => { if (e.Key == "Enter") isMinutesInputMode = false; })" />
                    }
                    <div class="time-content-wrapper"><span class="time-value">@displayMinutes.ToString("D2")</span><span class="time-label">мин</span></div>
                </div>
                <div class="time-zone bottom" @onmousedown='(e) => HandleZoneClick("minutes", -1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                </div>
            </div>
        </div>

        <div class="setting-block"><MudSwitch Value="isNightMode" T="bool" ValueChanged="ToggleNightMode" Label="Ночной режим" Color="Color.Secondary" Disabled="@(!_isAppReady)" /></div>
        
        <div class="setting-block">
            <MudSwitch Value="isRadioEnabled" T="bool" ValueChanged="ToggleRadio" Label="Радио" Disabled="@(!_isAppReady)" Color="Color.Secondary" />
            <div class="slider-wrapper @(isRadioEnabled ? "is-visible" : "")">
                <MudSlider T="int" Value="radioVolume" ValueChanged="UpdateRadioVolume" Disabled="@(!_isAppReady)" Min="0" Max="100" Color="Color.Secondary" />
                <span class="volume-label">Громкость: @radioVolume%</span>
            </div>
        </div>

        <div class="setting-block">
            <MudSwitch Value="isRainEnabled" T="bool" ValueChanged="ToggleRain" Label="Дождь" Disabled="@(!_isAppReady)" Color="Color.Info" />
            <div class="slider-wrapper @(isRainEnabled ? "is-visible" : "")">
                <MudSlider T="int" Value="rainVolume" ValueChanged="UpdateRainVolume" Disabled="@(!_isAppReady)" Min="0" Max="100" Color="Color.Info" />
                <span class="volume-label">Громкость: @rainVolume%</span>
            </div>
        </div>

        <div class="setting-block">
            <MudSwitch Value="isThunderEnabled" T="bool" ValueChanged="ToggleThunder" Label="Гром" Disabled="@(!_isAppReady)" Color="Color.Warning" />
            <div class="slider-wrapper @(isThunderEnabled ? "is-visible" : "")">
                <MudSlider T="int" Value="thunderVolume" ValueChanged="UpdateThunderVolume" Disabled="@(!_isAppReady)" Min="0" Max="100" Color="Color.Warning" />
                <span class="volume-label">Громкость: @thunderVolume%</span>
            </div>
        </div>

        <div class="setting-block">
            <MudSwitch Value="isBirdsEnabled" T="bool" ValueChanged="ToggleBirds" Label="Птицы" Disabled="@(!_isAppReady)" Color="Color.Success" />
            <div class="slider-wrapper @(isBirdsEnabled ? "is-visible" : "")">
                <MudSlider T="int" Value="birdsVolume" ValueChanged="UpdateBirdsVolume" Disabled="@(!_isAppReady)" Min="0" Max="100" Color="Color.Success" />
                <span class="volume-label">Громкость: @birdsVolume%</span>
            </div>
        </div>

        <div class="setting-block"><MudSwitch Value="playFog" T="bool" ValueChanged="ToggleFog" Label="Туман" Color="Color.Info" Disabled="@(!_isAppReady)" /></div>



<div class="d-flex gap-2 mb-4">
    <div class="diary-container flex-grow-1 justify-center py-2">
        <MudIconButton Icon="@Icons.Material.Filled.EmojiEvents" 
                       Variant="Variant.Filled" 
                       Color="Color.Warning" 
                       OnClick="OpenLeaderboard" 
                       Title="Таблица лидеров" 
                       Class="diary-button" />
    </div>

    <div class="diary-container flex-grow-1 justify-center py-2">
        <MudIconButton Icon="@Icons.Material.Filled.AssignmentTurnedIn" 
                       Variant="Variant.Filled" 
                       Color="Color.Success" 
                       OnClick="OpenDiary" 
                       Title="Открыть дневник" 
                       Class="diary-button" />
    </div>

    <div class="diary-container flex-grow-1 justify-center py-2">
        <MudIconButton Icon="@Icons.Material.Filled.MenuBook" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="OpenCollection" 
                       Title="Книга рыболова" 
                       Class="diary-button" />
    </div>
</div>
        @if (showDevTools)
        {
            <div class="mt-auto pt-4 border-t-1" style="border-top: 1px solid rgba(255,255,255,0.1)">
                <TestTools IsRunning="@isRunning" SelectedMinutes="@selectedMinutes" OnFastForward="@(() => secondsLeft = 5)" />
            </div>
        }
    </div> 
</div>

<audio id="radio-audio" src="@currentTrackUrl" @onended="PlayNextTrack"></audio>
<audio id="thunder-audio" src="audio/thunder.mp3" loop></audio>
<audio id="birds-audio" src="audio/birds.mp3" loop></audio>
<audio id="rain-audio" src="audio/rain.mp3" loop></audio>
<audio id="fish-sound1" src="audio/fish-sound1.mp3"></audio>
<audio id="fish-sound2" src="audio/fish-sound2.mp3"></audio>
<audio id="fish-warning" src="audio/fish-warning.mp3"></audio>

<style>
    .avatar-nav-btn {
        background: none;
        border: none;
        padding: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .avatar-nav-btn:hover {
        transform: scale(1.05);
    }
    .nav-avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-weight: bold;
        font-size: 0.95rem;
        overflow: hidden;
        border: 1.5px solid rgba(255,255,255,0.3);
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }
    .nav-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .profile-nav-card {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1.5px solid rgba(255, 255, 255, 0.1);
        padding: 8px 12px;
        border-radius: 12px;
        transition: background-color 0.2s;
    }
    .profile-nav-card:hover {
        background: rgba(255, 255, 255, 0.08);
    }
    .profile-nav-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .profile-nav-name {
        font-weight: bold;
        font-size: 0.9rem;
        color: #ffffff;
        line-height: 1.2;
    }
    .day-theme .profile-nav-name {
        color: #1a252f;
    }
    .profile-nav-score {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
    }
    .day-theme .profile-nav-score {
        color: rgba(0, 0, 0, 0.6);
    }
    .day-theme .profile-nav-card {
        background: rgba(0, 0, 0, 0.03);
        border-color: rgba(0, 0, 0, 0.08);
    }
    .day-theme .profile-nav-card:hover {
        background: rgba(0, 0, 0, 0.06);
    }
    .day-theme .nav-avatar-circle {
        border-color: rgba(0, 0, 0, 0.2);
    }
</style>

