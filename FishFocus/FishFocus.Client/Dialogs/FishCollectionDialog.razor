@using FishFocus.Shared.Models
@using MudBlazor
@inject IDialogService DialogService

<MudDialog Class="@(IsNightMode ? "dialog-night" : "dialog-day")">
    <TitleContent>
        <div class="d-flex align-center">
            <MudText Typo="Typo.h6" Class="theme-title">Пойманные рыбы</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 500px; overflow-y: auto; overflow-x: hidden;">
            @if (GroupedFish == null || !GroupedFish.Any())
            {
                <div class="d-flex flex-column align-center py-10">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
                    <MudText Class="mt-2" Color="Color.Secondary">Вы еще не поймали ни одной рыбы...</MudText>
                </div>
            }
            else
            {
                <div class="collection-grid">
                    @foreach (var item in GroupedFish)
                    {
                        <div class="fish-collection-card rarity-@(item.Fish.Rarity)" 
                             @onclick="() => ShowDetails(item.Fish)" 
                             style="cursor: pointer; position: relative;">
                             
                            <div class="fish-count-badge" style="position: absolute; top: 5px; right: 5px;">x@(item.Count)</div>
                            
                            <div class="fish-card-image">
                                @if (!string.IsNullOrEmpty(item.Fish.ImageUrl))
                                {
                                    <MudImage Src="@item.Fish.ImageUrl" Width="80" Height="80" ObjectFit="ObjectFit.Contain" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Size="Size.Large" Color="Color.Default" />
                                }
                            </div>
                            <div class="fish-card-info">
                                <div class="fish-card-name">@item.Fish.Name</div>
                                <div class="fish-card-desc">@item.Fish.Description</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Text" OnClick="() => MudDialog.Close()">Закрыть</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .dialog-day {
        background-color: #ffffff !important;
        color: #2c3e50 !important;
    }
    .dialog-night {
        background-color: #151d2a !important;
        color: #ffffff !important;
    }
    .dialog-day .theme-title { color: #1a252f !important; }
    .dialog-night .theme-title { color: #ffffff !important; }

    .dialog-day .fish-collection-card {
        background: #f8f9fa !important;
        border: 1px solid #e9ecef !important;
        color: #2c3e50 !important;
    }
    .dialog-night .fish-collection-card {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        color: #ffffff !important;
    }
    .dialog-day .fish-card-name { color: #1a252f !important; font-weight: bold; }
    .dialog-night .fish-card-name { color: #ffffff !important; font-weight: bold; }
    .dialog-day .fish-card-desc { color: #5a697d !important; }
    .dialog-night .fish-card-desc { color: #8a99ad !important; }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public bool IsNightMode { get; set; }
    [Parameter] public List<FishCatchResult> CatchHistory { get; set; } = new();

    private List<FishGroup> GroupedFish => CatchHistory
        .Where(c => c.Fish != null)
        .GroupBy(c => c.Fish.Name)
        .Select(g => new FishGroup { 
            Fish = g.First().Fish, 
            Count = g.Count() 
        })
        .OrderByDescending(g => g.Fish.Rarity)
        .ToList();

    private class FishGroup
    {
        public Fish Fish { get; set; } = null!;
        public int Count { get; set; }
    }

    private async Task ShowDetails(Fish fish)
    {
        var parameters = new DialogParameters { ["Fish"] = fish, ["IsNightMode"] = IsNightMode };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogService.ShowAsync<FishDetailsDialog>(fish.Name, parameters, options);
    }
}